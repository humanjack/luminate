# Anthropic API (for LLM features)
ANTHROPIC_API_KEY=sk-ant-...

# SpeechSuper API (for speech analysis)
SPEECHSUPER_API_KEY=your-api-key
SPEECHSUPER_APP_ID=your-app-id

# ELSA API (alternative speech analysis)
ELSA_API_KEY=your-elsa-api-key

# Google/YouTube API (for YouTube uploads)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
